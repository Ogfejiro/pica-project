<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verify your email</title>
  </head>
  <body style="font-family: sans-serif; background: #f4f4f4; padding: 40px">
    <div
      style="max-width: 560px; margin: 0 auto; background: #fff; border-radius: 8px; padding: 32px"
    >
      <h1 style="color: #0d9488">Verify your email address</h1>
      <p style="color: #374151">Welcome to PICA</p>
      <p style="color: #374151">
        Use the code below to verify your email. It expires in
        <strong><%= expiresInMinutes %> minutes</strong>.
      </p>
      <div style="text-align: center; margin: 32px 0">
        <span
          style="
            display: inline-block;
            font-size: 36px;
            font-weight: 700;
            letter-spacing: 8px;
            color: #0d9488;
            background: #f0fdf4;
            border: 2px dashed #0d9488;
            border-radius: 8px;
            padding: 12px 28px;
          "
          ><%= otp %></span
        >
      </div>
      <p style="color: #6b7280; font-size: 13px">
        If you did not request this, you can safely ignore this email.
      </p>
    </div>
  </body>
</html>
