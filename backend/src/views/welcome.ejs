<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Welcome to Pica</title>
  </head>
  <body style="font-family: sans-serif; background: #f4f4f4; padding: 40px">
    <div
      style="max-width: 560px; margin: 0 auto; background: #fff; border-radius: 8px; padding: 32px"
    >
      <h1 style="color: #0d9488">Welcome aboard, <%= businessName %>!</h1>
      <p style="color: #374151">
        We're thrilled to have you on PICA. Your account has been created and is ready to use.
      </p>
      <p style="color: #6b7280; font-size: 13px">
        If you did not create this account, please ignore this email.
      </p>
    </div>
  </body>
</html>
